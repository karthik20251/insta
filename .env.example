# Copy to .env and fill in
START_DATE=2026-05-11

# From Meta Graph API
IG_USER_ID=
IG_ACCESS_TOKEN=

# Hosting the video (pick ONE backend)
# github  → commit output/ to a public repo and read via raw URL (recommended, persistent)
# transfer → upload to transfer.sh (works without GitHub, ephemeral)
UPLOAD_BACKEND=github
GITHUB_RAW_BASE=https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/output
